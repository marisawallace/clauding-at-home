# Setup:
#
# cp .env.example .env
#
# Then update with your values, if needed.
#
# All directory variables set in this file are independent.
# README.md shows the conventional structure (the defaults), but you can
# point these at totally different locations on your drive and everything
# will work. I plan to keep these locations independent.


# Directory to search for claude.ai and chatgpt.com export zip files.
# Required for imports. Recommend making this your browser's downloads folder.
ZIP_SEARCH_DIR=~/Downloads


# Where canonical extracted claude.ai and chatgpt.com history is stored.
# Defaults to <repo>/data/llm_data/
#
# LLM_DATA_DIR=~/code/scrying-at-home/data/llm_data


# Archive for claude.ai and chatgpt.com .zip exports
# Defaults to <repo>/data/archived_exports/
#
# ARCHIVED_EXPORTS_DIR=~/code/scrying-at-home/data/archived_exports/


# Directory for all local views (Markdown and HTML) generated from claude.ai,
# chatgpt.com, and Claude Code sessions. These are persisted to disk, but
# any time you open one (v or h in search), scrying-at-home checks to see if
# (1) you have made no edits to the file and (2) there are new messages in the
# conversation since the file was generated. If (1) and (2) are both true, the
# local view is regenerated, then opened, so you get a fresh copy.
#
# Defaults to <repo>/data/local_views/
#
# LOCAL_VIEWS_DIR=~/code/scrying-at-home/data/local_views/


# Per-machine identity for local-CLI archives (Claude Code + Codex), set
# automatically by the setup migrations (002 for Claude Code, 004 for Codex).
#
# MACHINE_NAME=laptop
#
# A human-readable name for THIS machine. Canonically just your $HOSTNAME, but
# we need a variable because $HOSTNAME isn't stable on OSX. It is shared by
# every provider — it tags which archive subdir this machine writes to and
# attributes search results (and --here) to the originating box.
# (The pre-rename name CLAUDE_CODE_HOST is still read as a fallback.)
#
# MACHINE_NAME and the matching *_SOURCES line must both be set for that
# provider's archive + search to work.
#
# CLAUDE_CODE_SOURCES=laptop=/home/code/scrying-at-home/data/llm_data/claude-code/laptop,desktop=/home/code/scrying-at-home/data/llm_data/claude-code/desktop
#
# Comma-separated hostname=path pairs. Each path is the archive root for
# JSONL transcripts captured on that machine. This is what makes multi-machine
# sync work.
#
# scrying-at-home matches MACHINE_NAME against search results, and highlights
# the host display in orange, if you're on the same machine.


# The SQLite file for the search index. Must be stored on a local filesystem.
# Default:
# SEARCH_INDEX_DB=~/.cache/scrying-at-home/index.db
